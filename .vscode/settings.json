{
    "yaml.schemas": {
        "https://raw.githubusercontent.com/Nuitka/Nuitka/develop/nuitka/package_config/nuitka-package-config-schema.json": "tools/*nuitka-package.config.yml"
    },
    "githubIssues.queries": [
        {
            "label": "P0",
            "query": "state:open repo:${owner}/${repository} sort:updated-desc label:P0",
        },
        {
            "label": "P1",
            "query": "state:open repo:${owner}/${repository} sort:updated-desc label:P1"
        },
        {
            "label": "P2",
            "query": "state:open repo:${owner}/${repository} sort:updated-desc label:P2"
        },
        {
            "label": "P3",
            "query": "state:open repo:${owner}/${repository} sort:updated-desc label:P3"
        },
        {
            "label": "Bug",
            "query": "state:open repo:${owner}/${repository} sort:updated-desc label:Bug",
            "groupBy": [
                "milestone"
            ]
        },
        {
            "label": "Feature",
            "query": "state:open repo:${owner}/${repository} sort:updated-desc label:新功能",
            "groupBy": [
                "milestone"
            ]
        },
    ],
}
